<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>儲值總表 - Nova Analytics</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#F9FAFB;color:#1E293B;font-size:14px;line-height:1.5;min-height:100vh}
a{color:#3B82F6;text-decoration:none}
.layout{display:flex;min-height:100vh}
.sidebar{width:240px;background:rgba(255,255,255,.85);backdrop-filter:blur(12px);border-right:1px solid rgba(148,163,184,.15);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:10;transition:width .3s ease}
.sidebar.collapsed{width:60px}.sidebar.collapsed .sidebar-logo-text{display:none}.sidebar.collapsed .menu-item{justify-content:center;padding:12px 0;font-size:0;overflow:hidden}.sidebar.collapsed .menu-item svg{font-size:initial;width:20px;height:20px}.sidebar.collapsed .menu-item span{display:none}.sidebar.collapsed .menu-group-title{display:none}.sidebar.collapsed .sidebar-user-info{display:none}.sidebar.collapsed .sidebar-user{justify-content:center;padding:12px 0}.main.sidebar-collapsed{margin-left:60px}
.sidebar-logo{padding:16px 20px;border-bottom:1px solid rgba(148,163,184,.15);display:flex;align-items:center;gap:12px;position:relative}
.sidebar-logo-icon{width:40px;height:40px;flex-shrink:0}.sidebar-logo-icon img{width:40px;height:40px;display:block}
.sidebar-logo-text{display:flex;flex-direction:column;line-height:1.2}
.sidebar-logo-text .logo-nova{font-size:20px;font-weight:700;background:linear-gradient(to right,#3B82F6,#06B6D4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.sidebar-logo-text .logo-analytics{font-size:10px;font-weight:400;color:#94A3B8;letter-spacing:0.2em;text-transform:uppercase}
.sidebar-menu{flex:1;padding:12px 8px;overflow-y:auto}
.menu-group{padding:0}
.menu-group+.menu-group{margin-top:16px}.menu-group-title{padding:8px 16px 4px;font-size:12px;color:#9CA3AF;font-weight:500;letter-spacing:.3px}
.menu-item{display:flex;align-items:center;padding:10px 16px;color:#374151;cursor:pointer;transition:all .15s;font-size:14px;gap:10px;border-radius:8px;margin:2px 0;text-decoration:none}
.menu-item:hover{background:rgba(59,130,246,.06);color:#1E293B}
.menu-item.active{background:rgba(59,130,246,.1);color:#3B82F6;font-weight:500}
.menu-item svg{width:16px;height:16px;flex-shrink:0}
.sidebar-footer{padding:0;border-top:1px solid rgba(148,163,184,.15)}
.sidebar-user{display:flex;align-items:center;gap:10px;padding:12px 16px;cursor:pointer;transition:all .2s}
.sidebar-user:hover{background:rgba(59,130,246,.06)}.sidebar-user-info{flex:1;min-width:0}
.main{margin-left:240px;flex:1;display:flex;flex-direction:column}
.topbar{height:56px;background:rgba(255,255,255,.8);backdrop-filter:blur(12px);border-bottom:1px solid rgba(148,163,184,.12);display:flex;align-items:center;padding:0 28px;position:sticky;top:0;z-index:5;gap:12px}
.breadcrumb{display:flex;align-items:center;gap:6px;font-size:13px;color:#94A3B8}.breadcrumb span.current{color:#1E293B;font-weight:500}
.topbar-right{display:flex;align-items:center;gap:12px;margin-left:auto}
.topbar-icon-btn{width:36px;height:36px;border:1px solid rgba(148,163,184,.15);border-radius:10px;background:rgba(255,255,255,.8);display:flex;align-items:center;justify-content:center;cursor:pointer;color:#64748B;transition:all .2s}
.topbar-icon-btn:hover{background:#fff;color:#334155;border-color:rgba(59,130,246,.3)}
.content{padding:28px;flex:1}
.card{background:rgba(255,255,255,.6);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.6);border-radius:26px;padding:24px 0;box-shadow:0 1px 2px rgba(0,0,0,.05);margin-bottom:24px;transition:.3s cubic-bezier(.4,0,.2,1)}
.card:hover{transform:translateY(-4px);box-shadow:0 16px 40px rgba(0,0,0,.12),0 4px 12px rgba(0,0,0,.08)}
.card-header{padding:0 24px}
.card-title{font-size:18px;font-weight:700;color:#1f2937;display:flex;align-items:center;gap:8px;letter-spacing:-0.01em}.card-title::before{content:'';width:6px;height:20px;background:#3B82F6;border-radius:9999px;box-shadow:0 0 8px rgba(59,130,246,0.5)}
.card-desc{font-size:12px;color:#6b7280;margin-top:6px;font-weight:500}
.card-content{padding:0 24px}
.filter-section{background:rgba(255,255,255,.6);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.6);border-radius:26px;padding:24px;box-shadow:0 1px 2px rgba(0,0,0,.05);margin-bottom:24px}
.filter-row{display:flex;gap:16px;flex-wrap:wrap;align-items:flex-end}
.filter-group{display:flex;flex-direction:column;gap:6px}.filter-label{font-size:14px;font-weight:600;color:#64748B}
.filter-btn{display:inline-flex;align-items:center;gap:8px;padding:8px 12px;border:1px solid #E5E7EB;border-radius:8px;font-size:14px;height:40px;background:#F8FAFC;color:#1E293B;cursor:pointer;white-space:nowrap;transition:all .15s}.filter-btn:hover{border-color:#94A3B8}
.filter-btn svg{width:16px;height:16px;color:#94A3B8;flex-shrink:0}
.btn-query{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:8px 16px;border:none;border-radius:8px;font-size:14px;height:40px;background:#2563EB;color:#fff;font-weight:700;cursor:pointer;transition:all .15s}.btn-query:hover{background:#1d4ed8}
.btn-reset{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:8px 24px;border:1px solid #E2E8F0;border-radius:8px;font-size:14px;height:40px;background:#F8FAFC;color:#64748B;font-weight:500;cursor:pointer;transition:all .15s}.btn-reset:hover{background:#F1F5F9}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;font-size:13px;cursor:pointer;border:1px solid transparent;transition:all .2s;font-weight:500}
.btn-primary{background:#2563EB;color:#fff;border:none;font-weight:700}.btn-primary:hover{background:#1d4ed8}
.btn-outline{background:#fff;color:#64748B;border:1px solid #E5E7EB}.btn-outline:hover{background:#F9FAFB}
.table-wrap{overflow-x:auto;border-radius:8px}
table{width:100%;border-collapse:collapse}
th{background:#F9FAFB;padding:12px 14px;text-align:left;font-size:12px;color:#64748B;font-weight:600;border-bottom:1px solid #E5E7EB;white-space:nowrap}
td{padding:12px 14px;border-bottom:1px solid #F1F5F9;font-size:13px;color:#334155}
tr:hover td{background:rgba(59,130,246,.02)}
td a{color:#2563EB;font-weight:500}
.pagination{display:flex;align-items:center;justify-content:space-between;margin-top:16px;font-size:13px;color:#64748B}
.page-btn{padding:6px 11px;border:1px solid #E5E7EB;border-radius:6px;background:#fff;cursor:pointer;font-size:12px;color:#64748B}.page-btn.active{background:#2563EB;color:#fff;border-color:#2563EB}.page-btn:disabled{opacity:.4;cursor:not-allowed}
.avatar{width:32px;height:32px;border-radius:10px;background:linear-gradient(135deg,#3B82F6,#06B6D4);color:#fff;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600}
.sidebar-collapse-btn{position:absolute;right:12px;top:50%;transform:translateY(-50%);width:28px;height:28px;background:#fff;border:1px solid #E5E7EB;border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#94A3B8;transition:all .2s}.sidebar-collapse-btn:hover{border-color:#3B82F6;color:#3B82F6}
::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:#D0D5DD;border-radius:3px}
.mobile-menu-btn{display:none;width:36px;height:36px;border:1px solid #E5E7EB;border-radius:8px;background:#fff;align-items:center;justify-content:center;cursor:pointer;color:#64748B;flex-shrink:0}
.sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:90}
.sidebar-overlay.show{display:block}
@media(max-width:768px){html,body{overflow-x:hidden;max-width:100vw}.sidebar{width:240px;transform:translateX(-100%);position:fixed;z-index:100}.sidebar.mobile-open{transform:translateX(0)}.main{margin-left:0}.topbar{padding:0 16px}.content{padding:16px}.filter-row{flex-direction:column}.filter-input,.filter-select{width:100%}.mobile-menu-btn{display:flex}.table-wrap{display:block;overflow-x:auto;-webkit-overflow-scrolling:touch;max-width:calc(100vw - 32px)}table{min-width:600px}.filter-section{overflow:hidden}}

.user-popover{display:none;position:fixed;left:248px;bottom:12px;background:#fff;border:1px solid rgba(148,163,184,.15);border-radius:12px;box-shadow:0 8px 30px rgba(0,0,0,.12);min-width:220px;z-index:100;overflow:hidden}
.user-popover.show{display:block}
.popover-item{display:flex;align-items:center;gap:10px;padding:10px 16px;font-size:13px;color:#374151;cursor:pointer;transition:all .15s}
.popover-item:hover{background:#F3F4F6}
.popover-logout{color:#3B82F6}
.popover-divider{height:1px;background:#E5E7EB;margin:4px 0}
.popover-user{display:flex;align-items:center;gap:10px;padding:10px 16px}
.popover-avatar{width:32px;height:32px;border-radius:50%;background:#EAB308;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:600;font-size:13px;flex-shrink:0}
.popover-user-info{display:flex;flex-direction:column}
.popover-user-name{font-size:13px;font-weight:600;color:#111827}
.popover-user-email{font-size:11px;color:#6B7280}
.sidebar-nav{flex:1;overflow-y:auto;overflow-x:hidden;padding:8px}.sidebar-footer{flex-shrink:0;border-top:1px solid rgba(148,163,184,.15)}.sidebar-header{flex-shrink:0}
.chip-group{display:flex;gap:6px}.chip{display:inline-flex;align-items:center;gap:4px;padding:6px 12px;border-radius:16px;font-size:12px;cursor:pointer;border:1px solid #E5E7EB;background:#fff;color:#64748B;transition:all .2s}.chip input{display:none}.chip.active{background:#EFF6FF;border-color:#3B82F6;color:#2563EB;font-weight:500}
</style>
</head>
<body>
<div class="layout">
<aside class="sidebar" id="analyticsSidebar"></aside>
<script src="components/analytics-sidebar.js"></script>
<div class="main">
<div class="topbar"><button class="mobile-menu-btn" onclick="document.getElementById('analyticsSidebar').classList.add('mobile-open');document.getElementById('sidebarOverlay').classList.add('show')"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button><div class="breadcrumb"><span>儲值報表</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg><span class="current">儲值總表</span></div><div class="topbar-right"><div class="topbar-icon-btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg></div><div class="topbar-icon-btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg></div></div></div>
<div class="content"><div class="filter-section"><div class="filter-row">
<div class="filter-group"><label class="filter-label">日期範圍</label><button class="filter-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>2026/04/28 - 2026/05/05<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></button></div>
<div class="filter-group"><label class="filter-label">VIP 等級</label><button class="filter-btn">全部 VIP<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></button></div>
<div class="filter-group"><label class="filter-label">儲值方式</label><button class="filter-btn">全部方式<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></button></div>
<div class="filter-group"><label class="filter-label">裝置平台</label><button class="filter-btn">全部平台<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></button></div>
<div class="filter-group"><label class="filter-label">儲值幣別</label><button class="filter-btn">金幣, 星幣<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></button></div>
<div class="filter-group" style="align-self:flex-end"><button class="btn-query">查詢</button></div>
<div class="filter-group" style="align-self:flex-end"><button class="btn-reset">重置</button></div>
</div></div>
<div class="card"><div class="card-header"><div class="card-title">儲值總覽趨勢</div><div class="card-desc">每日儲值點數總額（不含贈點）、付費人數分析</div></div><div class="card-content"><div id="trendChart" style="height:320px;margin-top:16px"></div></div></div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">
<div class="card" style="margin-bottom:0"><div class="card-header"><div class="card-title">儲值分佈</div><div class="card-desc">分析玩家儲值金額的區間與人數佔比。</div></div><div class="card-content"><div id="distChart" style="height:288px;margin-top:12px"></div></div></div>
<div class="card" style="margin-bottom:0"><div class="card-header"><div class="card-title">渠道儲值佔比</div><div class="card-desc">分析各儲值管道的金額貢獻度與佔比。</div></div><div class="card-content"><div style="margin-top:12px"><label class="filter-label">Group by</label><button class="filter-btn" style="margin-top:6px">通路商<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></button></div><div id="pieChart" style="height:240px;margin-top:8px"></div><div style="font-size:11px;color:#94A3B8;margin-top:4px">＊點擊區塊檢視明細</div></div></div>
</div>
</div>
</div>
</div>
<script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
<script>
// 儲值總覽趨勢 - 堆疊柱狀圖 + 折線
const trend = echarts.init(document.getElementById('trendChart'));
trend.setOption({
  tooltip:{trigger:'axis',axisPointer:{type:'shadow'}},
  legend:{data:['金幣','星幣','付費人數'],top:0,textStyle:{fontSize:12,color:'#64748B'}},
  grid:{left:50,right:50,top:40,bottom:30},
  xAxis:{type:'category',data:['4/28','4/29','4/30','5/1','5/2','5/3','5/4'],axisLine:{lineStyle:{color:'#E5E7EB'}},axisLabel:{color:'#94A3B8'}},
  yAxis:[{type:'value',name:'幣量',nameLocation:'end',nameTextStyle:{color:'#64748B',fontSize:12},axisLabel:{color:'#94A3B8'},splitLine:{lineStyle:{color:'#F1F5F9'}}},{type:'value',name:'付費人數（人）',nameLocation:'end',nameTextStyle:{color:'#64748B',fontSize:12},axisLabel:{color:'#94A3B8'},splitLine:{show:false}}],
  series:[
    {name:'金幣',type:'bar',stack:'total',data:[8000,9500,7000,10500,8500,9500,7500],itemStyle:{color:'#3B82F6',borderRadius:[0,0,2,2]},barWidth:'60%'},
    {name:'星幣',type:'bar',stack:'total',data:[2000,1500,1500,2500,1400,1500,1500],itemStyle:{color:'#F59E0B',borderRadius:[2,2,0,0]}},
    {name:'付費人數',type:'line',yAxisIndex:1,data:[4,5,3,6,4,5,3],symbol:'circle',symbolSize:8,itemStyle:{color:'#EF4444'},lineStyle:{width:2}}
  ]
});
// 儲值分佈 - 柱狀圖
const dist = echarts.init(document.getElementById('distChart'));
dist.setOption({
  tooltip:{trigger:'axis',axisPointer:{type:'shadow'},formatter:function(p){return p[0].name+'<br/>'+p[0].marker+p[0].value+' 人'}},
  grid:{left:50,right:20,top:30,bottom:40},
  xAxis:{type:'category',name:'儲值金額',nameLocation:'end',nameTextStyle:{color:'#64748B'},data:['300以下','301~1k','1k~3k','3k~5k','5k+'],axisLine:{lineStyle:{color:'#E5E7EB'}},axisLabel:{color:'#94A3B8',fontSize:11}},
  yAxis:{type:'value',name:'人數（人）',nameLocation:'end',nameTextStyle:{color:'#64748B'},axisLabel:{color:'#94A3B8'},splitLine:{lineStyle:{color:'#F1F5F9'}}},
  series:[{type:'bar',data:[11,6,2,1,2],itemStyle:{color:'#10B981',borderRadius:[3,3,0,0]},barWidth:'50%',label:{show:true,position:'top',formatter:'{c} 人',fontSize:11,color:'#334155'}}]
});
// 渠道儲值佔比 - 圓餅圖
const pie = echarts.init(document.getElementById('pieChart'));
pie.setOption({
  tooltip:{trigger:'item',formatter:'{b}: {c} ({d}%)'},
  legend:{orient:'vertical',right:10,top:'middle',textStyle:{color:'#64748B',fontSize:12}},
  series:[{type:'pie',radius:['0%','70%'],center:['35%','50%'],data:[{value:44,name:'Mycard',itemStyle:{color:'#3B82F6'}},{value:32,name:'Gash',itemStyle:{color:'#F59E0B'}},{value:24,name:'FOG',itemStyle:{color:'#10B981'}}],label:{show:true,formatter:'{d}%',fontSize:12,color:'#fff',position:'inside'},emphasis:{itemStyle:{shadowBlur:10,shadowColor:'rgba(0,0,0,.2)'}}}]
});
pie.on('click',function(p){alert('明細：'+p.name+'\n佔比：'+p.percent+'%\n金額：'+(p.value*1000).toLocaleString()+' 點')});
window.addEventListener('resize',function(){trend.resize();dist.resize();pie.resize()});
</script>